{
  "manifest_version": 3,
  "name": "AntiTube",
  "version": "1.0.0",
  "description": "Hides YouTube Shorts after 7 videos or 7 minutes — whichever comes first.",

  "permissions": [
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AntiTube"
  }
}
